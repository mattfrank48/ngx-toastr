{
  "name": "@iqx-limited/ngx-toastr",
  "description": "Toastr for Angular",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IQXLimited/ngx-toastr.git"
  },
  "version": "2.2.2",
  "license": "MIT",
  "author": "IQX Limited",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "demo:build": "ng build --configuration production --no-progress --base-href 'https://iqxlimited.github.io/ngx-toastr/'",
    "build": "ng-packagr -p src/lib/ng-package.json",
    "postbuild": "cpy README.md LICENSE dist",
    "test": "ng test --watch=false",
    "test:watch": "ng test",
    "test:ci": "ng test --watch=false --code-coverage --no-progress --browsers=ChromeHeadlessCustom",
    "lint": "npx --yes eslint",
    "lint:fix": "npx --yes eslint --fix",
    "tsc-verify": "npx --yes tsc --build"
  },
  "type": "module",
  "private": true,
  "devDependencies": {
    "@angular-eslint/builder": "^21.3.1",
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/template-parser": "^21.1.0",
    "@angular/build": "^21.2.16",
    "@angular/cli": "^21.2.16",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/compiler-cli": "^21.2.17",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.2.17",
    "@angular/language-service": "^21.2.17",
    "@angular/platform-browser": "^21.1.0",
    "@angular/platform-browser-dynamic": "^21.2.17",
    "@angular/router": "^21.2.17",
    "@ctrl/ngx-github-buttons": "^9.0.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/jasmine": "^6.0.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.9.4",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "angular-eslint": "^21.4.0",
    "bootstrap": "^5.3.8",
    "cpy-cli": "^7.0.0",
    "jasmine-core": "^6.3.0",
    "jasmine-spec-reporter": "^7.0.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-coverage-istanbul-reporter": "^3.0.3",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "lodash-es": "^4.18.1",
    "ng-packagr": "^21.2.5",
    "puppeteer": "^24.43.1",
    "rxjs": "^7.8.2",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1"
  },
  "release": {
    "branches": [
      "master"
    ]
  },
  "volta": {
    "node": "24.17.0"
  }
}
